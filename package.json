{
  "name": "tmaster",
  "version": "0.1.0",
  "private": true,
  "description": "AI-gesteuerter Terminal-Orchestrator",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3",
    "dev": "concurrently -k \"pnpm:dev:renderer\" \"pnpm:dev:main\" \"pnpm:dev:preload\" \"pnpm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:preload": "node scripts/build-preload.mjs --watch",
    "dev:electron": "wait-on dist/main/index.js dist/preload/index.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 nodemon --delay 1 --watch dist/main --watch dist/preload --ext js --exec \"electron --no-sandbox .\"",
    "build": "run-s build:main build:preload build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "build:preload": "node scripts/build-preload.mjs",
    "build:renderer": "vite build",
    "start": "electron .",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.mcp.json --noEmit",
    "pretest": "pnpm rebuild better-sqlite3",
    "test": "vitest run",
    "posttest": "electron-rebuild -f -w node-pty,better-sqlite3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "better-sqlite3": "^12.6.2",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xterm": "^5.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
